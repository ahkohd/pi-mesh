{
  "name": "@ahkohd/pi-mesh",
  "version": "0.1.1",
  "description": "P2P Pi agent mesh with pluggable discovery connectors.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ahkohd/pi-mesh.git"
  },
  "bugs": {
    "url": "https://github.com/ahkohd/pi-mesh/issues"
  },
  "homepage": "https://github.com/ahkohd/pi-mesh#readme",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "pi-mesh": "bin/pi-mesh.js",
    "pi-mesh-tailscale": "bin/pi-mesh-tailscale.js"
  },
  "pi": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "files": [
    "bin",
    "dist",
    "LICENSE.md",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "cargo test && npm run typecheck",
    "pack:dry": "npm pack --dry-run",
    "version:sync": "node scripts/sync-npm-version.cjs"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "^0.78.0",
    "typebox": "^1.1.38"
  },
  "optionalDependencies": {
    "@ahkohd/pi-mesh-darwin-arm64": "0.1.1",
    "@ahkohd/pi-mesh-darwin-x64": "0.1.1",
    "@ahkohd/pi-mesh-linux-arm64-gnu": "0.1.1",
    "@ahkohd/pi-mesh-linux-x64-gnu": "0.1.1"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=20"
  }
}
